{$APP_ADDRESS:http://localhost} {
  log {
    output stdout
    format json
  }

  handle /media/proxy/* {
    reverse_proxy app:3000
  }

  handle_path /media/* {
    root * /srv/media
    header Cache-Control "public, max-age=31536000, immutable"
    header Cross-Origin-Resource-Policy "cross-origin"
    file_server
  }

  handle {
    reverse_proxy app:3000
  }
}

BOOMIMAGE_IMAGE=ghcr.io/facjxzdt/boomimage:latest

# Public URL seen by browsers and copied image links.
APP_BASE_URL=http://localhost

# Caddy is kept as the internal static-media gateway.
# It listens inside the container on :80 and is exposed to the host on 127.0.0.1:3001 by default.
# Put your own Nginx in front of http://127.0.0.1:3001 for HTTPS/public traffic.
APP_ADDRESS=:80
CADDY_HTTP_BIND=127.0.0.1:3001
# APP_BASE_URL=https://img.example.com

# Generate a random value of at least 32 characters before production use.
# Production startup refuses missing, template, or obvious placeholder values.
APP_SECRET=replace-with-a-random-secret-at-least-32-characters
SESSION_TTL_SECONDS=2592000
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

APP_HOST=0.0.0.0
APP_PORT=3000
APP_DATA_DIR=/data
WEB_DIST_DIR=/app/apps/web/dist
LOG_LEVEL=info

MAX_UPLOAD_BYTES=52428800
MAX_INPUT_PIXELS=50000000
TMP_FILE_TTL_SECONDS=86400
TMP_CLEANUP_INTERVAL_SECONDS=3600
IMAGE_WORKERS=2
JOB_POLL_INTERVAL_MS=1000
JOB_LEASE_SECONDS=300
JOB_MAX_ATTEMPTS=3
AVIF_QUALITY=50
AVIF_EFFORT=4
WEBP_QUALITY=82

# Storage for new uploads by default. The web UI/API can still choose local or s3 per upload.
STORAGE_DRIVER=local

# S3-compatible storage. Required only when using STORAGE_DRIVER=s3 or selecting S3 per upload.
# S3_ACCESS_MODE controls the default S3 link style for uploads: direct or proxy.
# For AWS S3, usually leave S3_ENDPOINT empty and set S3_REGION.
# For Cloudflare R2/MinIO/other S3-compatible services, set S3_ENDPOINT and usually S3_FORCE_PATH_STYLE=true.
S3_ACCESS_MODE=proxy
S3_ENDPOINT=
S3_REGION=auto
S3_BUCKET=
S3_PREFIX=boomimage
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_SESSION_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
